__pycache__/
*.pyc
.venv/
venv/
.env
.env.*
!.env.example

# Superflow (workflow tooling — not part of feature deliverable)
.superflow-state.json
.superflow/
.par-evidence.json
.worktrees/
# Ignore everything in .claude/ (session state, local settings) except the
# skills/ subtree, which holds project-level skill artifacts that SHOULD be
# committed. The `/*` form is required for the `!` negation to apply to
# subdirectories — `.claude/` would exclude the dir itself.
.claude/*
!.claude/skills/
